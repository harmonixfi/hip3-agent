# Copy to `.arbit_env` and fill in values. Do not commit `.arbit_env`.

# --- Paradex ---
export PARADEX_JWT="your_paradex_jwt_token_here"
export PARADEX_ACCOUNT_ADDRESS="0xYourParadexAddress"

# --- Ethereal ---
export ETHEREAL_ACCOUNT_ADDRESS="0xYourEthereumAddress"
export ETHEREAL_SUBACCOUNT_ID=""

# --- Hyperliquid / Lighter (optional; defaults if empty) ---
# Wallet config for Hyperliquid is now in config/strategies.json (each strategy's wallets[]).
# HYPERLIQUID_ACCOUNTS_JSON is NO LONGER used.
# HYPERLIQUID_ADDRESS is kept as legacy single-wallet fallback for bootstrap scenarios
# (only used when strategies.json has no wallets for hyperliquid venue).
export HYPERLIQUID_ADDRESS=""
export LIGHTER_L1_ADDRESS=""

# --- Felix equities (optional — delta-neutral equity snapshots in pm_account_snapshots) ---
# FELIX_EQUITIES_JWT is short-lived; rotate manually in `.arbit_env` when requests return 401.
# FELIX_WALLET_ADDRESS — ledger address for pm_account_snapshots / DN equity (your primary id).
# FELIX_API_ACCOUNT_ADDRESS — optional. If the proxy only authorizes GET /v1/portfolio/{id} for a
# different id than FELIX_WALLET_ADDRESS (same user, two chain identities), set this to that id.
# Requests use FELIX_API_ACCOUNT_ADDRESS in the URL; snapshots still use FELIX_WALLET_ADDRESS as account_id.
# export FELIX_WALLET_ADDRESS="0xYourLedgerWallet"
# export FELIX_API_ACCOUNT_ADDRESS="0xFelixPathWallet"
# export FELIX_EQUITIES_JWT="your_bearer_jwt"

# --- Harmonix NAV Postgres (optional — vault lending equity) ---
# Uncomment and set `HARMONIX_NAV_DB_URL` to enable `LendingProvider`.
# Reference: `tracking/vault/providers/lending.py`

# export HARMONIX_NAV_DB_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Wallets (comma-separated): same list for ERC4626 + Aave. Optional if you rely on defaults / `config_json.lending_accounts`.
# export HARMONIX_LENDING_ACCOUNT_ADDRESSES="0xaddr1,0xaddr2"

# export HARMONIX_LENDING_CHAIN_ID="999"
# export HARMONIX_LENDING_ERC4626_VAULTS="0xvault1,0xvault2"
# export HARMONIX_LENDING_USDC_ADDRESS="0xb88339CB7199b77E23DB6E890353E22632Ba630f"
