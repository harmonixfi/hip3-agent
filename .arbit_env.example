# Arbit Environment Variables Example
# Copy this file to .arbit_env and fill in your values
# DO NOT commit .arbit_env to version control

# Paradex
# Get JWT from Paradex dashboard or API
export PARADEX_JWT="your_paradex_jwt_token_here"
export PARADEX_ACCOUNT_ADDRESS="0xYourParadexAddress"

# Ethereal
# Your Ethereum account address
export ETHEREAL_ACCOUNT_ADDRESS="0xYourEthereumAddress"
# Optional: Ethereal subaccount ID
export ETHEREAL_SUBACCOUNT_ID=""

# Hyperliquid
# Optional: If different from ETHEREAL_ACCOUNT_ADDRESS
export HYPERLIQUID_ADDRESS=""

# Lighter
# Optional: If different from ETHEREAL_ACCOUNT_ADDRESS
export LIGHTER_L1_ADDRESS=""

# harmonix-nav-platform PostgreSQL (vault LendingProvider — optional)
# export HARMONIX_NAV_DB_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
# Lending equity = sum of latest per-vault underlying from raw ERC4626 hourly (defaults in tracking/vault/providers/lending.py)
# export HARMONIX_LENDING_CHAIN_ID="999"
# export HARMONIX_LENDING_ERC4626_ACCOUNT="0x..."
# export HARMONIX_LENDING_ERC4626_VAULTS="0xvault1,0xvault2"
